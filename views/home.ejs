<%- include('partials/header', {titulo: 'Início' }) %>

  <!-- ── NAVIGATION ── -->
  <%- include('partials/navbar', {titulo: 'Início' }) %>

    <!-- ── MAIN CONTENT ── -->
    <main>
      <!-- Hero Card -->
      <section class="card hero-card">
        <div class="hero-content">
          <span class="hero-icon">🩷</span>
          <h2>Bem-vindo ao Helptopia!</h2>
          <p>
            Seu guia definitivo para Heartopia, um jogo aconchegante de
            simulação de vida criado para criatividade, liberdade e paz.
            Explore, crie e prospere em seu próprio mundo tranquilo!
          </p>
        </div>
        <div class="hero-image">
          <img src="Heartopia.png" alt="Heartopia" />
        </div>
      </section>

      <!-- About Card -->
      <section class="card about-card">
        <h3 class="section-title"><span>✨</span> Sobre Heartopia</h3>
        <p>
          Heartopia é um mundo tranquilo onde você pode construir a vida dos
          seus sonhos no seu próprio ritmo. Plante jardins, crie itens lindos,
          faça amizade com os moradores e crie seu santuário perfeito.
        </p>
        <p>
          Seja coletando recursos, decorando sua casa ou lucrando com suas
          criações, Heartopia oferece possibilidades infinitas para jogabilidade
          pacífica e expressão criativa.
        </p>
      </section>

      <!-- Features Grid -->
      <div class="features-grid">
        <div class="feature-card">
          <h4 class="feature-title">
            <span>🌸</span>
            <span class="title-pink">Liberdade Criativa</span>
          </h4>
          <p>
            Projete seu mundo perfeito com infinitas opções de personalização e
            ferramentas criativas.
          </p>
        </div>

        <div class="feature-card">
          <h4 class="feature-title">
            <span>🔥</span>
            <span class="title-orange">Criação Lucrativa</span>
          </h4>
          <p>
            Aprenda quais itens vendem melhor e maximize seus lucros com nosso
            guia detalhado.
          </p>
        </div>

        <div class="feature-card">
          <h4 class="feature-title">
            <span>🗺️</span>
            <span class="title-teal">Localização de Recursos</span>
          </h4>
          <p>
            Descubra onde encontrar todos os materiais que você precisa com
            nosso mapa abrangente.
          </p>
        </div>

        <div class="feature-card">
          <h4 class="feature-title">
            <span>👥</span>
            <span class="title-green">Comunidade</span>
          </h4>
          <p>
            Junte-se a uma comunidade pacífica de jogadores que amam jogos
            aconchegantes de simulação de vida.
          </p>
        </div>
      </div>
    </main>

    <!-- FOOTER -->
    <%- include('partials/footer') %>